#!/bin/bash
set -euo pipefail

srcdir="$(mktemp -d)"
trap 'rm -rf "${srcdir}"' EXIT
git clone --depth=1 --revision=0fbc9f99d5a28865f9de8427fb0672d66f9d83a5 \
  https://github.com/the-mikedavis/tree-sitter-git-config.git "${srcdir}"

tree-sitter build --output=git_config.so "${srcdir}"
# mkdir -p ~/.local/share/nvim/site/queries/git_config
# cp -R "${srcdir}/queries/editorconfig/" ~/.local/share/nvim/site/queries/git_config
