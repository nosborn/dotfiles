#!/bin/bash
set -euo pipefail

repo=ValdezFOmar/tree-sitter-xresources
if command -v gh &>/dev/null; then
  tag_name="$(gh api "/repos/${repo}/releases/latest" --jq .tag_name)"
else
  tag_name="$(curl -fLsS "https://api.github.com/repos/${repo}/releases/latest" | jq -r .tag_name)"
fi

srcdir="$(mktemp -d)"
trap 'rm -rf "${srcdir}"' EXIT
git clone --branch="${tag_name}" --depth=1 "https://github.com/${repo}.git" "${srcdir}"

tree-sitter build --output=xresources.so "${srcdir}"
# mkdir -p ~/.local/share/nvim/site/queries/xresources
# cp -R "${srcdir}/queries/editorconfig/" ~/.local/share/nvim/site/queries/xresources
