#!/bin/bash
set -euo pipefail

srcdir="$(mktemp -d)"
trap 'rm -rf "${srcdir}"' EXIT
git clone --depth=1 --revision=760ba8e34e7a68294ffb9c495e1388e030366188 \
  https://github.com/the-mikedavis/tree-sitter-git-rebase.git "${srcdir}"

tree-sitter build --output=git_rebase.so "${srcdir}"
# mkdir -p ~/.local/share/nvim/site/queries/git_rebase
# cp -R "${srcdir}/queries/editorconfig/" ~/.local/share/nvim/site/queries/git_rebase
