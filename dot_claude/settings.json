{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "medium",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "GIT_CONFIG_GLOBAL": "/dev/null",
    "GIT_CONFIG_NOSYSTEM": "1"
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754056529971
  },
  "permissions": {
    "allow": [
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(shellcheck *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(sudo *)",
      "Read(**/*.pem)",
      "Read(**/.age.key.txt)",
      "Read(**/.aws/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/.envrc.*)",
      "Read(**/.gnupg/**)",
      "Read(**/.ssh/**)",
      "Read(**/.vault_password)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "docker"
    ],
    "failIfUnavailable": true,
    "filesystem": {
      "allowRead": [
        "."
      ],
      "allowWrite": [
        "."
      ],
      "denyRead": [
        "~/"
      ],
      "denyWrite": [
        "/"
      ]
    }
  },
  "showTurnDuration": false,
  "spinnerTipsEnabled": false,
  "terminalProgressBarEnabled": true
}
